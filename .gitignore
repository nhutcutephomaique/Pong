# This .gitignore is tailored for Unity projects
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

# OS generated files
/[Oo]bj/
/[Tt]emp/
/[Bb]in/
/[Ll]ibrary/
/[Uu]ser[Ss]ettings/
/.vs/
/.idea/

# Visual Studio / Rider specific
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd

# Unity generated
sysinfo.txt
memorycapture.raw
*.apk
*.aab
*.unitypackage

# Asset meta data
*.pidb.meta
*.pdb

# Autogenerated JetBrains Rider plugin
.idea/

# Crash reports
crash.log

# Build results
/Build/
